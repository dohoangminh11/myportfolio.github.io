---
import { siteConfig } from "../config";
---

{siteConfig.available && (
  <div class="availability">
    <span class="dot"></span>
    <span class="text">Disponible</span>

    <div class="tooltip">
      Je recherche une alternance 👀
    </div>
  </div>
)}

<style>
.availability {
  position: fixed;
  bottom: 24px;
  right: 24px;
  display: flex;
  align-items: center;
  gap: 10px;
  background: #111;
  color: white;
  padding: 10px 14px;
  border-radius: 999px;
  font-size: 14px;
  cursor: default;
  box-shadow: 0 10px 25px rgba(0,0,0,0.15);
  transition: transform 0.2s ease, background 0.2s ease;
  z-index: 1000;
  position: fixed;
}

.availability:hover {
  transform: scale(1.05);
  background: #222;
}

/* Dot animé */
.dot {
  width: 10px;
  height: 10px;
  background: #00ff88;
  border-radius: 50%;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(0,255,136, 0.7); }
  70% { box-shadow: 0 0 0 10px rgba(0,255,136, 0); }
  100% { box-shadow: 0 0 0 0 rgba(0,255,136, 0); }
}

/* Tooltip */
.tooltip {
  position: absolute;
  bottom: 130%;
  right: 0;
  background: white;
  color: black;
  padding: 8px 12px;
  border-radius: 10px;
  font-size: 13px;
  white-space: nowrap;
  box-shadow: 0 10px 20px rgba(0,0,0,0.15);

  opacity: 0;
  transform: translateY(10px);
  pointer-events: none;
  transition: all 0.2s ease;
}

/* Apparition au hover */
.availability:hover .tooltip {
  opacity: 1;
  transform: translateY(0);
}
</style>

